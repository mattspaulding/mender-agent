# Copy to deploy/config.env (gitignored), edit, then run deploy/deploy.sh.

# --- required ---
PROJECT_ID=rapid-agent-hackathon-495414
REGION=us-central1

# --- container + service names (defaults are fine) ---
REPO=mender
IMAGE_NAME=mender
MENDER_SERVICE=mender
FINPAY_SERVICE=finpay
SCHEDULER_JOB=mender-heartbeat

# --- runtime config ---
SCHEDULER_CRON="*/15 * * * *"
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space
FINPAY_PROMPT_VERSION=v2

# --- Secret Manager secret names (must exist; deploy script does NOT create them) ---
SECRET_PHOENIX_API_KEY=phoenix-api-key
SECRET_SLACK_WEBHOOK=slack-incoming-webhook
SECRET_SLACK_SIGNING=slack-signing-secret
