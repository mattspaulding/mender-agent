# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=rapid-agent-hackathon-495414
GOOGLE_CLOUD_LOCATION=us-central1
# ADK uses Vertex AI by default when this is set; otherwise it falls back to AI Studio.
GOOGLE_GENAI_USE_VERTEXAI=true

# --- Models ---
# Mender's reasoning model. Override per-call from BUILD_SCOPE if needed.
MENDER_MODEL=gemini-3-flash-preview
FINPAY_MODEL=gemini-3-flash-preview
# Optional: surgically promote individual reasoning steps to a stronger model
# (e.g. hypothesis-generation, patch-generation) when Flash quality is too weak.
# Reserved for future use; not yet wired.
# MENDER_REASONING_MODEL=gemini-3.1-pro-preview

# --- Phoenix Cloud ---
# Sign up at https://app.phoenix.arize.com, copy the API key.
PHOENIX_API_KEY=
# Cloud collector endpoint (no trailing slash). For Arize-hosted Phoenix Cloud
# this MUST include your space path: https://app.phoenix.arize.com/s/<your-space>
# Find it on your Phoenix Cloud landing page (URL after sign-in).
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
# Same URL — used by @arizeai/phoenix-mcp for REST calls.
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space
# Phoenix project names default to "finpay-support" (FinPay traces) and
# "mender" (Mender's own traces). Override only if you want them combined.
# PHOENIX_PROJECT_NAME=

# --- FinPay (target agent) ---
FINPAY_HOST=127.0.0.1
FINPAY_PORT=8081
# Which versioned prompt to serve from prompts/finpay/. The traffic
# generator + eval runner both read this. Bumping it simulates a
# "model upgrade event."
FINPAY_PROMPT_VERSION=v1

# --- Mender ---
# How far back each heartbeat scans. Format: 60m, 6h, 24h.
MENDER_WINDOW=60m

# --- Slack (filled in later) ---
SLACK_INCOMING_WEBHOOK=
SLACK_SIGNING_SECRET=
